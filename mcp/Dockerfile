# ==========================================
# GoZero-AI MCP服务 Docker镜像构建文件
# ==========================================
# 功能: 构建文档处理微服务(MCP)的容器镜像
# 架构: 多阶段构建，分离编译环境和运行环境，优化镜像大小
# 服务: 提供gRPC接口，支持PDF文档解析和文本提取
# 端口: 8321 (gRPC服务端口)
# 依赖: UniPDF商业版许可证，支持高级PDF处理功能
#
# 构建命令: docker build -t gozero-ai-mcp .
# 运行命令: docker run -p 8321:8321 gozero-ai-mcp

# ==========================================
# 第一阶段：构建环境 (Builder Stage)
# ==========================================
# 使用官方Go 1.24.6镜像作为编译基础环境
# 注意：这里使用了Go 1.24.6版本，根据实际项目需求调整版本号
# 第一阶段：构建（这里以你自己的 go 版本为准）
FROM golang:1.24.6 AS builder

# ==========================================
# Go环境变量和代理配置
# ==========================================
# 启用Go模块支持，确保使用现代化的Go模块管理系统
# 设置环境变量
ENV GO111MODULE=on
# 配置Go模块代理，使用国内镜像源加速依赖下载
# goproxy.cn: 七牛云提供的Go模块代理服务，提升国内下载速度
# direct: 直连模式，当代理不可用时直接从源站下载
ENV GOPROXY=https://goproxy.cn,direct

# ==========================================
# 项目源码复制和编译配置
# ==========================================
# 设置构建时的工作目录，所有构建操作在此目录下执行
# 设置工作目录
WORKDIR /build

# 复制整个项目源码到构建容器内
# 注意：应考虑使用.dockerignore文件排除不必要的文件，优化构建效率
# 复制项目文件
COPY . .

# ==========================================
# MCP服务编译构建
# ==========================================
# 注意：这里有一个配置错误 - 应该切换到MCP目录而非API目录
# 建议修正为: WORKDIR /build/mcp
# 构建应用
WORKDIR /build/mcp
# 编译MCP服务二进制文件
# CGO_ENABLED=0: 禁用CGO，生成纯静态二进制文件，提高跨平台兼容性
# GOOS=linux: 目标操作系统为Linux，适配Alpine容器环境
# -o /output/mcp: 指定输出文件路径和名称
# .: 编译当前目录下的所有Go源码文件
RUN CGO_ENABLED=0 GOOS=linux go build -o /output/mcp .

# ==========================================
# 第二阶段：运行环境 (Runtime Stage)
# ==========================================
# 使用最新Alpine Linux作为运行时基础镜像
# Alpine优势：极小的镜像大小(~5MB)、最小的攻击面、快速启动
# 第二阶段：运行
FROM alpine:latest

# ==========================================
# 运行时目录结构初始化
# ==========================================
# 创建MCP服务需要的配置文件目录结构
# /mcp/etc: 存放服务配置文件的目录
# 创建配置目录
RUN mkdir -p /mcp/etc

# ==========================================
# 二进制文件和配置文件复制
# ==========================================
# 从构建阶段复制Docker环境的配置文件
# docker.yaml -> mcp.yaml: 适配不同环境的配置文件命名约定
# 注意：这里将docker.yaml重命名为chat.yaml，可能需要根据实际配置调整
# 复制配置文件和可执行文件
COPY --from=builder /build/mcp/etc/docker.yaml /mcp/etc/mcp.yaml
# 从构建阶段复制编译好的MCP服务二进制文件
# --from=builder: 指定源阶段为builder
# /output/mcp: 构建阶段编译输出的二进制文件路径
COPY --from=builder /output/mcp /mcp/

# ==========================================
# 服务启动配置
# ==========================================
# 设置运行时工作目录，所有命令在此目录下执行
WORKDIR /mcp
# 定义容器启动时的默认执行命令
# ./mcp: 执行编译好的MCP服务二进制文件
# 服务将自动加载同目录下的配置文件(etc/chat.yaml)
CMD ["./mcp"]