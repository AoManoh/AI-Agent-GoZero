# ==========================================
# GoZero-AI API服务 Docker镜像构建文件
# ==========================================
# 功能: 构建AI对话系统的主业务API服务容器镜像
# 架构: 多阶段构建，分离编译环境和运行环境，优化镜像大小和安全性
# 服务: 提供RESTful API接口，支持流式对话和RAG知识库检索
# 端口: 8123 (HTTP API服务端口)
#
# 构建命令: docker build -t gozero-ai-api .
# 运行命令: docker run -p 8123:8123 gozero-ai-api

# ==========================================
# 第一阶段：构建环境 (Builder Stage)
# ==========================================
# 使用官方Go 1.24.6镜像作为编译基础环境
# 注意：这里使用了Go 1.24.6版本，根据实际项目需求调整版本号
# 第一阶段：构建（这里以你自己的 go 版本为准）
FROM golang:1.24.6 AS builder

# ==========================================
# Go环境变量和代理配置
# ==========================================
# 启用Go模块支持，确保使用现代化的Go模块管理系统
# 设置环境变量
ENV GO111MODULE=on
# 配置Go模块代理，使用国内镜像源加速依赖下载
# goproxy.cn: 七牛云提供的Go模块代理服务，提升国内下载速度
# direct: 直连模式，当代理不可用时直接从源站下载
ENV GOPROXY=https://goproxy.cn,direct

# ==========================================
# 项目源码复制和编译配置
# ==========================================
# 设置构建时的工作目录，所有构建操作在此目录下执行
# 设置工作目录
WORKDIR /build

# 复制整个项目源码到构建容器内
# 注意：应考虑使用.dockerignore文件排除不必要的文件，优化构建效率
# 复制项目文件
COPY . .

# ==========================================
# API服务编译构建
# ==========================================
# 切换到API服务的源码目录，准备编译API服务
# 构建应用
WORKDIR /build/api/chat
# 编译API服务二进制文件
# CGO_ENABLED=0: 禁用CGO，生成纯静态二进制文件，提高跨平台兼容性
# GOOS=linux: 目标操作系统为Linux，适配容器环境
# -o /output/api: 指定输出文件路径和名称
# .: 编译当前目录下的所有Go源码文件
RUN CGO_ENABLED=0 GOOS=linux go build -o /output/api .

# ==========================================
# 第二阶段：运行环境 (Runtime Stage)
# ==========================================
# 使用最新Alpine Linux作为运行时基础镜像
# Alpine优势：极小的镜像大小(~5MB)、最小的攻击面、快速启动
# 第二阶段：运行
FROM alpine:latest

# ==========================================
# 运行时目录结构初始化
# ==========================================
# 创建API服务需要的配置文件目录结构
# /api/etc: 存放服务配置文件的目录
# 创建配置目录
RUN mkdir -p /api/chat/etc

# ==========================================
# 二进制文件和配置文件复制
# ==========================================
# 从构建阶段复制Docker环境的配置文件
# docker.yaml: Docker容器环境下的专用配置，包含容器化部署的特定设置
# 复制配置文件和可执行文件
COPY --from=builder /build/api/chat/etc/docker.yaml /api/chat/etc/chat.yaml
# 从构建阶段复制编译好的API服务二进制文件
# --from=builder: 指定源阶段为builder
# /output/api: 构建阶段编译输出的二进制文件路径
COPY --from=builder /output/api /api/chat/api

# ==========================================
# 服务启动配置
# ==========================================
# 设置运行时工作目录，所有命令在此目录下执行
WORKDIR /api/chat
# 定义容器启动时的默认执行命令
# ./api: 执行编译好的API服务二进制文件
# 服务将自动加载同目录下的配置文件(etc/docker.yaml)
CMD ["./api"]