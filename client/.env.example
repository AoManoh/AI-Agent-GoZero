# ==========================================
# GoZero-AI 前端环境变量配置示例
# ==========================================
# 
# 使用说明:
# 1. 复制此文件为 .env.development (开发环境) 或 .env.production (生产环境)
# 2. 根据实际部署环境修改 API 地址
# 
# 开发环境: 
#   VITE_API_BASE_URL=http://localhost:8123/api
# 
# 生产环境 (使用 Nginx 反向代理):
#   VITE_API_BASE_URL=/api
# 
# ==========================================

# API 服务基础地址
# 开发环境示例: http://localhost:8123/api
# 生产环境示例: /api (使用相对路径，通过 Nginx 代理)
VITE_API_BASE_URL=http://localhost:8123/api
