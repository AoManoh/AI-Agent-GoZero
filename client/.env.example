# ==========================================
# GoZero-AI 前端环境变量配置示例
# ==========================================
# 
# 使用说明:
# 1. 复制此文件为 .env.development (开发环境) 或 .env.production (生产环境)
# 2. 根据实际部署环境修改 API 地址
# 
# 开发环境:
#   VITE_API_BASE_URL=/api
#   VITE_USER_API_BASE_URL=/api
#   VITE_CHAT_API_BASE_URL=/api
#   VITE_DEV_USER_PROXY_TARGET=http://127.0.0.1:8124
#   VITE_DEV_CHAT_PROXY_TARGET=http://127.0.0.1:8123
# 
# 生产环境 (使用 Nginx 反向代理):
#   VITE_API_BASE_URL=/api
# 
# ==========================================

# API 服务基础地址
# 本项目有 user-api(:8124) 与 chat-api(:8123) 两个 HTTP 服务。
# 前端默认通过同一个 /api 入口访问，再由 Vite/Nginx 按路径转发。
VITE_API_BASE_URL=/api
VITE_USER_API_BASE_URL=/api
VITE_CHAT_API_BASE_URL=/api

# Vite 开发代理目标
VITE_DEV_USER_PROXY_TARGET=http://127.0.0.1:8124
VITE_DEV_CHAT_PROXY_TARGET=http://127.0.0.1:8123
